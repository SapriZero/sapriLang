[package]
name = "urcm-core"
version = "0.3.0"
edition = "2021"

[dependencies]
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
reqwest = { version = "0.11", features = ["blocking", "json"], optional = true }
axum = "0.7"
tokio = { version = "1.0", features = ["full"] }
chrono = "0.4"

[features]
default = ["http"]
http = ["dep:reqwest"]

[lib]
name = "urcm_core"
path = "src/lib.rs"

